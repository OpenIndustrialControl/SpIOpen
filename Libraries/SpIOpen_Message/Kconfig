menu "SpIOpen Message Features"

config SPIOPEN_MESSAGE_ALLOW_HEAP_ALLOCATION_AT_INIT
    bool "Allow heap allocation during component initialization"
    default n
    help
        If enabled, lifecycle components that require backing memory (frame pools,
        mailbox queues, broker thread stack) may allocate missing storage during
        Initialize(). If disabled, all required backing memory must be provided
        through component configuration before initialization.

config SPIOPEN_MESSAGE_MAX_SUBSCRIBER_COUNT
    int "Maximum number of simultaneous subscribers supported by the frame broker"
    range 4 128
    default 8
    help
        This options accepts integer values from 4 to 255. Each app and port is a subscriber

config SPIOPEN_MESSAGE_FRAME_POOL_MAX_CC_FRAMES
    int "Maximum number of CAN-CC Frames that can be configured in the CC Frame Pool"
    range 0 255
    default 32
    help
        The maximum number of CAN-CC frames allowed in the Frame Pool.

config SPIOPEN_MESSAGE_FRAME_POOL_MAX_FD_FRAMES
    int "Maximum number of CAN-FD Frames that can be configured in the FD Frame Pool"
    range 0 255
    default 32
    help
        The maximum number of CAN-FD frames allowed in the Frame Pool.

config SPIOPEN_MESSAGE_FRAME_POOL_MAX_XL_FRAMES
    int "Maximum number of CAN-XL Frames that can be configured in the XL Frame Pool"
    range 0 255
    default 32
    help
        The maximum number of CAN-XL frames allowed in the Frame Pool.

config SPIOPEN_MESSAGE_MAILBOX_MAX_DEPTH
    int "Maximum mailbox depth for broker mailbox queues"
    range 1 255
    default 32
    help
        The maximum queue depth for each broker mailbox.
        This setting applies to broker inbox and subscriber mailboxes.

config SPIOPEN_MESSAGE_THREAD_MAX_STACK_SIZE
    int "Maximum broker thread stack size in bytes"
    range 128 65535
    default 2048
    help
        The maximum stack size used by the FrameBroker thread.

endmenu
