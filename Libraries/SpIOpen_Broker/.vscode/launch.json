{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug SpIOpen Broker Tests",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/tests/spiopen_broker_tests",
            "cwd": "${workspaceFolder}/build",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
